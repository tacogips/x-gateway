# Example environment for local `x-gateway` usage.
# The current stable live-request surface is GraphQL-only and requires bearer auth.

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Default mixed mode allows explicit parameters to override env values.
# Valid values: env | params | mixed
export X_GW_AUTH_MODE="mixed"

# Required for live GraphQL requests in the current repository state.
export X_GW_TOKEN="x-bearer-token"

# Optional placeholders for future auth adapters or mapping work.
# These do not enable live GraphQL requests by themselves today.
# export X_GW_CONSUMER_KEY="your-consumer-key"
# export X_GW_CONSUMER_SECRET="your-consumer-secret"
# export X_GW_ACCESS_TOKEN="your-access-token"
# export X_GW_ACCESS_TOKEN_SECRET="your-access-token-secret"
# export X_GW_CLIENT_ID="your-client-id"
# export X_GW_CLIENT_SECRET="your-client-secret"

# -----------------------------------------------------------------------------
# Optional gateway behavior
# -----------------------------------------------------------------------------

# Persisted-query requests default to https://x.com/i/api/graphql/<documentId>/<operationName>
# Inline-query requests default to https://x.com/i/api/graphql
# export X_GW_GRAPHQL_BASE_URL="https://x.com/i/api/graphql"
# export X_GW_OUTPUT="text"                    # text | json
# export X_GW_TIMEOUT_MS="30000"               # default: 30000
# export X_GW_RETRY="2"                        # default: 2
# export X_GW_RETRY_BACKOFF="exponential-jitter"  # exponential-jitter | fixed | none
# export X_GW_RETRY_BASE_MS="300"              # default: 300
# export X_GW_RETRY_MAX_MS="10000"             # default: 10000
# export X_GW_STRICT_CAPABILITY_CHECKS="false" # true | false
