{
  "name": "x-gateway",
  "version": "0.1.0",
  "description": "AI-oriented CLI and library gateway for X API",
  "type": "module",
  "main": "dist/lib.js",
  "module": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "x-gateway": "./dist/main.js",
    "x-gateway-reader": "./dist/main-reader.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "default": "./dist/lib.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "rm -rf dist && bun build src/lib.ts --outdir dist --target bun && bun build src/cli.ts --outdir dist --target bun && bun build src/main.ts --outdir dist --target bun && bun build src/main-reader.ts --outdir dist --target bun && tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist --rootDir src",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:ui": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "homepage": "https://github.com/user/repo",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/repo"
  },
  "license": "MIT",
  "trustedDependencies": [],
  "devDependencies": {
    "@types/bun": "1.1.14",
    "@vitest/ui": "2.1.8",
    "typescript": "5.7.2",
    "prettier": "3.4.2",
    "vitest": "2.1.8"
  },
  "dependencies": {
    "graphql": "16.13.1",
    "twitter-api-v2": "1.29.0"
  }
}
